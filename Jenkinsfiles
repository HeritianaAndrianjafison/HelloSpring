pipeline {
    agent any

    parameters {
        string(name: 'GIT_URL', defaultValue: '', description: 'URL du projet Spring Boot sur GitHub')
        string(name: 'PROJECT_NAME', defaultValue: '', description: 'Nom du projet (utilisé pour workspace et Docker)')
        string(name: 'APP_PORT', defaultValue: '8080', description: 'Port de l’application')
        string(name: 'REMOTE_HOST', defaultValue: '', description: 'Adresse IP ou nom du serveur distant')
        string(name: 'REMOTE_USER', defaultValue: 'root', description: 'Utilisateur SSH pour le serveur distant')
        string(name: 'SSH_KEY_PATH', defaultValue: '/home/heritiana/.ssh/id_rsa_jenkins', description: 'Chemin vers la clé SSH')
    }

    environment {
        WORKSPACE_DIR = "/home/heritiana/${params.PROJECT_NAME}"
        IMAGE_NAME = "${params.PROJECT_NAME}-image"
        CONTAINER_NAME = "${params.PROJECT_NAME}-container"
        DOCKER_BASE_IMAGE = "openjdk:17-slim"
    }

    stages {

        stage('Setup Tools on Jenkins') {
            steps {
                sh '''
                echo "Vérification et installation des outils sur Jenkins..."

                if ! command -v git &> /dev/null; then
                    sudo apt update && sudo apt install -y git
                fi

                if ! command -v mvn &> /dev/null; then
                    sudo apt update && sudo apt install -y maven
                fi

                if ! command -v docker &> /dev/null; then
                    sudo apt update && sudo apt install -y docker.io
                fi

                if ! command -v bzip2 &> /dev/null; then
                    sudo apt update && sudo apt install -y bzip2
                fi
                '''
            }
        }

        stage('Prepare Workspace') {
            steps {
                sh '''
                echo "Préparation du workspace pour ${PROJECT_NAME}..."
                rm -rf ${WORKSPACE_DIR} || true
                mkdir -p ${WORKSPACE_DIR}
                '''
            }
        }

        stage('Checkout') {
            steps {
                sh '''
                echo "Clonage du projet ${GIT_URL}..."
                git clone -b main ${GIT_URL} ${WORKSPACE_DIR}
                '''
            }
        }

        stage('Build JAR') {
            steps {
                sh '''
                echo "Construction du JAR pour ${PROJECT_NAME}..."
                cd ${WORKSPACE_DIR}
                mvn clean package
                '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                echo "Construction de l'image Docker ${IMAGE_NAME}..."
                cd ${WORKSPACE_DIR}

                if [ ! -f Dockerfile ]; then
                    cat > Dockerfile <<EOF
FROM ${DOCKER_BASE_IMAGE}
WORKDIR /app
COPY target/*.jar app.jar
EXPOSE ${APP_PORT}
ENTRYPOINT ["java","-jar","app.jar"]
EOF
                fi

                docker rmi -f ${IMAGE_NAME}:latest || true
                docker build -t ${IMAGE_NAME}:latest .
                '''
            }
        }

        stage('Deploy Container on Jenkins') {
            steps {
                sh '''
                echo "Déploiement du conteneur ${CONTAINER_NAME} sur Jenkins..."
                docker stop ${CONTAINER_NAME} || true
                docker rm ${CONTAINER_NAME} || true
                docker run -d --name ${CONTAINER_NAME} -p ${APP_PORT}:${APP_PORT} ${IMAGE_NAME}:latest
                '''
            }
        }

        stage('Deploy to Remote Server via SSH') {
            steps {
                sh '''
                echo "Déploiement de ${PROJECT_NAME} sur ${REMOTE_HOST}..."

                docker save ${IMAGE_NAME}:latest | bzip2 | ssh -i ${SSH_KEY_PATH} -o StrictHostKeyChecking=no ${REMOTE_USER}@${REMOTE_HOST} '
                    echo "Vérification et installation des outils sur le serveur distant..."

                    if ! command -v docker &> /dev/null; then
                        apt update && apt install -y docker.io
                    fi

                    if ! java -version &> /dev/null; then
                        apt update && apt install -y openjdk-17-jdk
                    fi

                    if ! command -v bzip2 &> /dev/null; then
                        apt update && apt install -y bzip2
                    fi

                    docker stop ${CONTAINER_NAME} || true
                    docker rm ${CONTAINER_NAME} || true
                    docker run -d --name ${CONTAINER_NAME} -p ${APP_PORT}:${APP_PORT} ${IMAGE_NAME}:latest
                '
                '''
            }
        }

    }

    post {
        success {
            echo "Application ${PROJECT_NAME} déployée sur Jenkins et ${params.REMOTE_HOST} (port ${APP_PORT})"
        }
        failure {
            echo "Le pipeline a échoué"
        }
    }
}